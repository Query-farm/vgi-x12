# name: test/sql/shaped.test
# group: [vgi_x12]
#
# Shaped positional views: read_835 / read_837 / read_271 / read_850 / read_997.
# Column names use public segment IDs + element position only; raw codes verbatim.

require-env VGI_X12_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'x12' AS x12 (TYPE vgi, LOCATION '${VGI_X12_WORKER}');

statement ok
SET search_path = 'x12.main';

# read_835: CLP1 (3 detail children) + CLP2 (bare) = 4 rows; header carried down.
query I
SELECT count(*) FROM read_835('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000123*0*P*:~GS*HP*PAYERAPP*PROVAPP*20240115*1200*1*X*005010X221A1~ST*835*0001~BPR*I*1500*C*ACH~TRN*1*TRACE0001*1512345678~NM1*PR*2*ACME HEALTH PLAN*****PI*PAYER001~NM1*PE*2*WELLNESS CLINIC LLC*****XX*1999999999~CLP*PCN1001*1*500*400*100*MC*CCN0001*11~CAS*CO*45*100~SVC*HC:99213*200*160**1~DTM*232*20240110~CLP*PCN1002*4*1000*0*0*MC*CCN0002*11~SE*11*0001~GE*1*1~IEA*1*000000123~');
----
4

query TTT
SELECT payer_name, payee_npi, clp_total_paid FROM read_835('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000123*0*P*:~GS*HP*PAYERAPP*PROVAPP*20240115*1200*1*X*005010X221A1~ST*835*0001~BPR*I*1500*C*ACH~TRN*1*TRACE0001*1512345678~NM1*PR*2*ACME HEALTH PLAN*****PI*PAYER001~NM1*PE*2*WELLNESS CLINIC LLC*****XX*1999999999~CLP*PCN1001*1*500*400*100*MC*CCN0001*11~CAS*CO*45*100~SE*8*0001~GE*1*1~IEA*1*000000123~') WHERE cas_reason_code = '45';
----
ACME HEALTH PLAN	1999999999	400

# read_837: pivoted NM1 columns + composite place-of-service + diagnosis code.
query TTTT
SELECT billing_provider_npi, subscriber_id, clm_place_of_service, hi_diagnosis_code
FROM read_837('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000200*0*P*:~GS*HC*SUBMITTER*RECEIVER*20240101*1200*1*X*005010X222A1~ST*837*0001~BHT*0019*00*REF01*20240101*1200*CH~NM1*85*2*BILLING CLINIC*****XX*1122334455~NM1*IL*1*DOE*JOHN****MI*MEMBER123~SBR*P*18**GROUP PLAN~NM1*QC*1*DOE*JANE~CLM*ACCT777*500***11:B:1*Y~HI*ABK:Z1234~SV1*HC:99213*200*UN*1~DTP*472*D8*20240105~SE*11*0001~GE*1*1~IEA*1*000000200~') WHERE hi_diagnosis_code IS NOT NULL;
----
1122334455	MEMBER123	11:B:1	Z1234

# read_271: HL1 bare + HL2 bare + HL3 (2 EB + 1 DTP) = 5 rows.
query I
SELECT count(*) FROM read_271('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000300*0*P*:~GS*HB*PAYERAPP*PROVAPP*20240101*1200*1*X*005010X279A1~ST*271*0001~BHT*0022*11*REF*20240101*1200~HL*1**20*1~NM1*PR*2*ACME PAYER*****PI*PAYER01~HL*2*1*21*1~NM1*1P*2*PROVIDER GRP*****XX*1444444444~HL*3*2*22*0~NM1*IL*1*DOE*JOHN****MI*MEMBER99~TRN*2*TRACE55*9999999999~EB*1*IND*30**GOLD PPO~EB*B*IND*30****27.5~DTP*291*D8*20240101~SE*13*0001~GE*1*1~IEA*1*000000300~');
----
5

query T
SELECT eb_benefit_amount FROM read_271('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000300*0*P*:~GS*HB*PAYERAPP*PROVAPP*20240101*1200*1*X*005010X279A1~ST*271*0001~HL*3*2*22*0~NM1*IL*1*DOE*JOHN****MI*MEMBER99~EB*B*IND*30****27.5~SE*4*0001~GE*1*1~IEA*1*000000300~') WHERE eb_benefit_amount IS NOT NULL;
----
27.5

# read_997: AK2#1 (AK3 + AK4) + AK2#2 (bare) = 3 rows; trailing AK5 status stamped.
query TT
SELECT ak2_transaction_control, ak5_status FROM read_997('ISA*00*          *00*          *ZZ*SENDER         *ZZ*RECEIVER       *240101*1200*^*00501*000000500*0*P*:~GS*FA*R*S*20240101*1300*1*X*005010X231A1~ST*997*0001~AK1*HC*1~AK2*837*0001~AK3*CLM*22**8~AK4*1*1028*1~AK5*E~AK2*837*0002~AK5*A~AK9*P*2*2*1~SE*10*0001~GE*1*1~IEA*1*000000500~') WHERE ak2_transaction_control = '0002';
----
0002	A

statement ok
USE memory;

statement ok
DETACH x12;
